# ============================================================
# Emailer — Production Environment (Vercel)
# ============================================================
# Set these in Vercel Project Settings → Environment Variables (Production).
# DO NOT commit a real .env.production file.
# ============================================================

# --- CONVEX (production deployment) ---
# These point the deployed Next.js app at the production Convex deployment.
# Run `npx convex deploy` once to provision the prod deployment, then read
# the URL from the Convex dashboard.
NEXT_PUBLIC_CONVEX_URL=https://fearless-kookaburra-668.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://fearless-kookaburra-668.convex.site

# Used only by `npx convex deploy` from CI. The .github/workflows/deploy-convex.yml
# expects CONVEX_DEPLOY_KEY as a secret instead of CONVEX_DEPLOYMENT here.
# CONVEX_DEPLOYMENT=prod:fearless-kookaburra-668

# ============================================================
# Set these in Convex Dashboard → Settings → Environment Variables
# (NOT in Vercel — Convex actions read their own env, not Vercel's)
# ============================================================

# Self-hosted Railway scraper
# SCRAPER_URL=https://scraper-production-b94c.up.railway.app

# /ingest-leads webhook auth — must match EMAILER_WEBHOOK_SECRET in n8n / claimory-growth
# WEBHOOK_SECRET=<rotate-me>

# Admin user lookup for inbound webhooks
# ADMIN_EMAIL=admin@claimory.io

# AI fallback (optional — only used when SCRAPER_URL fails)
# GOOGLE_AI_API_KEY=
# OPENAI_API_KEY=
