# ============================================================
# Emailer — Environment Variables
# Copy to .env.local for local dev.
# For production: set in Convex dashboard (Settings > Environment Variables)
# ============================================================

# --- NEXT.JS ---
NEXT_PUBLIC_CONVEX_URL=https://avid-cuttlefish-641.convex.cloud

# ============================================================
# Set these in Convex Dashboard > Settings > Environment Variables
# ============================================================

# --- SCRAPLING (self-hosted Google Maps scraper) ---
# Deploy claimory-growth/scraper/ to Railway, get the URL
SCRAPER_URL=https://your-scraper.railway.app

# --- WEBHOOK AUTH (for /ingest-leads HTTP action) ---
# Must match EMAILER_WEBHOOK_SECRET in claimory-growth/.env
WEBHOOK_SECRET=your-random-secret-here
# The email you registered with in the emailer — used to look up your userId
ADMIN_EMAIL=admin@claimory.io

# --- AI SERVICES ---
# OpenAI — reply classification + email copywriting
OPENAI_API_KEY=sk-...
# Google Gemini — AI lead generation fallback
GOOGLE_AI_API_KEY=AIza...

# --- EMAIL PROVIDERS (configure at least one) ---
# Option A: Resend (recommended, free tier 3k/mo)
RESEND_API_KEY=re_...
# Option B: SMTP (for Namecheap Private Email, Gmail, etc.)
SMTP_HOST=smtp.privateemail.com
SMTP_PORT=465
SMTP_USER=admin@claimory.io
SMTP_PASS=your-smtp-password
SMTP_SSL=true

# --- COLD EMAIL SENDER DOMAIN ---
# Register claimory-hq.com (separate from claimory.io to protect main domain)
# Then set up SMTP for that domain
FROM_EMAIL=artur@claimory-hq.com
FROM_NAME=Artur A.

# --- UNSUBSCRIBE / TRACKING ---
PUBLIC_BASE_URL=https://emailer.claimory.io
UNSUB_SECRET=another-random-secret-here

# --- LEAD SCRAPER FALLBACK (optional) ---
# Google Custom Search API — fallback when SCRAPER_URL is not set
# Get from: console.cloud.google.com > Custom Search JSON API
GOOGLE_SEARCH_API_KEY=AIza...
GOOGLE_SEARCH_ENGINE_ID=your-cx-id

# --- SOCIAL POSTING (optional, set up later) ---
X_CLIENT_ID=...
X_CLIENT_SECRET=...
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...
